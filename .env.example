# LLM provider
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_ID=qwen3
OLLAMA_API_KEY=
OLLAMA_TEMPERATURE=0

# Ollama Cloud option:
# 1. Create an API key in Ollama.
# 2. Use the host root here; backend/llm/ollama.py appends /api through ChatOllama.
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_MODEL_ID=minimax-m2.7:cloud
# OLLAMA_API_KEY=your_ollama_api_key

# Storage
DATA_DIR=Data
# Optional. When set to a postgres:// or postgresql:// URL, this takes priority over DATABASE_PATH.
DATABASE_URL=
DATABASE_PATH=Data/jarvis.db
KNOWLEDGE_VAULT_PATH=Data/knowledge_vault
# Assistant prompt context (optional; defaults to the server's local timezone)
ASSISTANT_TIMEZONE=

# Gmail (Phase 2 - optional)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

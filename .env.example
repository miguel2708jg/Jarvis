# LLM provider
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_ID=qwen3
OLLAMA_API_KEY=
OLLAMA_TEMPERATURE=0

# Ollama Cloud option:
# 1. Create an API key in Ollama.
# 2. Use the host root here; backend/llm/ollama.py appends /api through ChatOllama.
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_MODEL_ID=minimax-m2.7:cloud
# OLLAMA_API_KEY=your_ollama_api_key

# Storage
DATA_DIR=Data
# Optional. When set to a postgres:// or postgresql:// URL, this takes priority over DATABASE_PATH.
DATABASE_URL=
DATABASE_PATH=Data/jarvis.db
KNOWLEDGE_VAULT_PATH=Data/knowledge_vault
# Raw knowledge uploads default to local files under KNOWLEDGE_VAULT_PATH/raw/uploads.
# Set OBJECT_STORAGE_PROVIDER=s3 on Railway to store raw uploads in a private Railway Bucket.
OBJECT_STORAGE_PROVIDER=local
# Railway Bucket variable references map directly to these settings:
# S3_BUCKET=${{bucket.BUCKET}}
# S3_ENDPOINT=${{bucket.ENDPOINT}}
# S3_REGION=${{bucket.REGION}}
# S3_ACCESS_KEY_ID=${{bucket.ACCESS_KEY_ID}}
# S3_SECRET_ACCESS_KEY=${{bucket.SECRET_ACCESS_KEY}}
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Assistant prompt context (optional; defaults to the server's local timezone)
ASSISTANT_TIMEZONE=

# Voice I/O (optional)
STT_PROVIDER=groq
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo
# Empty means Groq auto-detects language.
GROQ_STT_LANGUAGE=
# Optional. Use this when ffmpeg is installed but not visible on PATH.
FFMPEG_PATH=ffmpeg
TTS_PROVIDER=piper
TTS_VOICE=en_US-lessac-medium
# Optional override. When empty, Jarvis uses /tmp/piper-voices/${TTS_VOICE}.onnx.
PIPER_MODEL_PATH=
PIPER_CONFIG_PATH=

# Gmail (Phase 2 - optional)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

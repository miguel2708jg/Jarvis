# LLM provider
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_ID=qwen3
OLLAMA_API_KEY=
OLLAMA_TEMPERATURE=0

# Ollama Cloud option:
# 1. Create an API key in Ollama.
# 2. Use the host root here; backend/llm/ollama.py appends /api through ChatOllama.
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_MODEL_ID=minimax-m2.7:cloud
# OLLAMA_API_KEY=your_ollama_api_key

# Storage
DATA_DIR=Data
# Required for normal runtime. Use your Neon postgres:// or postgresql:// connection URL.
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require
# Legacy/local recovery only. SQLite fallback is disabled unless ALLOW_SQLITE_FALLBACK=true.
DATABASE_PATH=Data/jarvis.db
ALLOW_SQLITE_FALLBACK=false
KNOWLEDGE_VAULT_PATH=Data/knowledge_vault
# Assistant prompt context (optional; defaults to the server's local timezone)
ASSISTANT_TIMEZONE=

# Google Workspace OAuth (Gmail, Calendar, Drive)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
# Keep false during normal backend runtime; set true only for a one-off local OAuth authorization run.
GOOGLE_ALLOW_INTERACTIVE_OAUTH=false

# Gmail MCP (optional, Google Workspace developer preview)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_MCP_ENDPOINT=https://gmailmcp.googleapis.com/mcp/v1
GMAIL_MCP_TIMEOUT_SECONDS=30

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

# Google social login (web)
AUTH_SECRET=replace_with_32_plus_random_chars
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
AUTH_ALLOWED_EMAILS=majg2708@gmail.com
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WS_URL=
BACKEND_API_URL=http://localhost:8000

# Trusted web -> backend auth. Use the same random value in Next and FastAPI.
BACKEND_INTERNAL_AUTH_TOKEN=replace_with_random_internal_token
BACKEND_AUTH_TOKEN_SECRET=replace_with_random_ws_signing_secret
